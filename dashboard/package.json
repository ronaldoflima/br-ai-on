{
  "name": "agents-dashboard",
  "version": "1.3.2",
  "private": true,
  "scripts": {
    "dev": "node --env-file=../.env ./node_modules/.bin/next dev --port 3040 --hostname 0.0.0.0",
    "build": "node --env-file=../.env ./node_modules/.bin/next build",
    "start": "node --env-file=../.env ./node_modules/.bin/next start --port 3040 --hostname 0.0.0.0",
    "release": "cd .. && ./release.sh"
  },
  "dependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/qrcode": "^1.5.6",
    "ansi-to-html": "^0.7.2",
    "isomorphic-dompurify": "^3.8.0",
    "next": "^15.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
